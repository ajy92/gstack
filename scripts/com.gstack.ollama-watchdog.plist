<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.gstack.ollama-watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/home/bin/ollama-watchdog.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/home/.hermes/profiles/gstack/logs/watchdog-stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/home/.hermes/profiles/gstack/logs/watchdog-stderr.log</string>
</dict>
</plist>
